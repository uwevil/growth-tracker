{
    "name": "growth-tracker",
    "version": "1.0.0",
    "description": "Suivi de croissance - taille, poids et tour de crâne",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc -p tsconfig.json && tsc -p tsconfig.client.json",
        "start": "node dist/server.js",
        "dev": "tsc -p tsconfig.client.json && ts-node src/server.ts",
        "build:server": "tsc -p tsconfig.json",
        "build:client": "tsc -p tsconfig.client.json"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.5",
        "nodemon": "^3.0.3",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}